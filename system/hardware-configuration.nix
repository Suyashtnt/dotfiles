      fsType = "btrfs";
      options = [ "subvol=root compress=zstd" ];
    };

  fileSystems."/nix" =
    { device = "/dev/disk/by-uuid/ccbfd0f1-bc70-4c83-a084-35f9893ccccc";
      fsType = "btrfs";
      options = [ "subvol=nix compress=zstd noatime" ];
    };

  fileSystems."/home" =
    { device = "/dev/disk/by-uuid/ccbfd0f1-bc70-4c83-a084-35f9893ccccc";
      fsType = "btrfs";
      options = [ "subvol=home compress=zstd" ];
